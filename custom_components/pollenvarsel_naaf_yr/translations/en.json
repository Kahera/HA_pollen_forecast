{
  "config": {
    "step": {
      "user": {
        "title": "NAAF/Yr Pollen Forecast",
        "description": "Add forecast for selected pollen types for a given location",
        "data": {
          "location_id": "Location ID",
          "location_name": "Location Name (optional)",
          "pollen_types": "Pollen Types",
          "update_frequency": "Update Frequency (hours)",
          "language": "Language"
        },
        "data_description": {
          "location_id": "The code can be found in the URL of the location on yr.no (e.g., 1-189277)",
          "location_name": "Override the location name shown in sensor names. Leave empty to use the region name from the NAAF data.",
          "pollen_types": "Select which pollen types to create sensors for",
          "update_frequency": "How often to fetch a new forecast",
          "language": "Language used for sensor names and API data"
        }
      }
    },
    "error": {
      "location_required": "Location ID is required"
    },
    "abort": {
      "already_configured": "This location is already configured"
    }
  },
  "selector": {
    "pollen_type": {
      "options": {
        "hazel": "Hazel",
        "alder": "Alder",
        "salix": "Salix",
        "birch": "Birch",
        "grass": "Grass",
        "mugwort": "Mugwort"
      }
    },
    "language": {
      "options": {
        "nb": "Norwegian (Bokmål)",
        "nn": "Norwegian (Nynorsk)",
        "en": "English"
      }
    }
  },
  "entity": {
    "sensor": {
      "pollen_today": {
        "name": "{pollen_type} today",
        "state": {
          "none": "None",
          "low": "Low",
          "moderate": "Moderate",
          "high": "High",
          "extreme": "Extreme"
        }
      },
      "pollen_tomorrow": {
        "name": "{pollen_type} tomorrow",
        "state": {
          "none": "[%key:component::pollenvarsel_naaf_yr::entity::sensor::pollen_today::state::none%]",
          "low": "[%key:component::pollenvarsel_naaf_yr::entity::sensor::pollen_today::state::low%]",
          "moderate": "[%key:component::pollenvarsel_naaf_yr::entity::sensor::pollen_today::state::moderate%]",
          "high": "[%key:component::pollenvarsel_naaf_yr::entity::sensor::pollen_today::state::high%]",
          "extreme": "[%key:component::pollenvarsel_naaf_yr::entity::sensor::pollen_today::state::extreme%]"
        }
      }
    }
  }
}
